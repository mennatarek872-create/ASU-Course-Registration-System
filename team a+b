void viewAllCourses() {
	if (courseCount == 0) { cout << "No courses available.\n"; return; }
	cout << "\n--- All Courses ---\n";
	cout << string(100, '-') << "\n";
	cout << left << setw(10) << "ID"
	             << setw(25) << "Course Name"
	             << setw(25) << "Instructor"
	             << setw(8)  << "Credits"
	             << setw(12) << "Day"
	             << setw(10) << "Time"
	             << "Available\n";
	cout << string(100, '-') << "\n";
	for (int i = 0; i < courseCount; i++) {
		int available = courses[i].MaxCapacity - courses[i].CurrentEnrolled;
		cout << left << setw(10) << courses[i].CourseID
		             << setw(25) << courses[i].CourseName
		             << setw(25) << courses[i].InstructorName
		             << setw(8)  << courses[i].CreditHours
		             << setw(12) << courses[i].Day
		             << setw(10) << courses[i].Time
		             << available << "\n";
	}
	cout << string(100, '-') << "\n";
}

void increaseStudentCount(int courseID) {
	int index = searchCourse(courseID);
	if (index == -1) { cout << "Course not found.\n"; return; }
	if (courses[index].CurrentEnrolled >= courses[index].MaxCapacity) {
		cout << "Course is full.\n"; return;
	}
	courses[index].CurrentEnrolled++;
	cout << "student added successfully.\n";
	saveCourses();
}

void decreaseStudentCount(int courseID) {
	int index = searchCourse(courseID);
	if (index == -1) { cout << "Course not found.\n"; return; }
	if (courses[index].CurrentEnrolled == 0) {
		cout << "No students to remove.\n"; return;
	}
	courses[index].CurrentEnrolled--;
	cout << "Student removed successfully.\n";
	saveCourses();
}




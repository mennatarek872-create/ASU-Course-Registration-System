void loadCourses() {
	ifstream file("courses.txt");
	if (!file) return;
	file >> courseCount;
	file.ignore();
	for (int i = 0; i < courseCount; i++) {
		file >> courses[i].CourseID;
		file.ignore();
		getline(file, courses[i].CourseName);
		getline(file, courses[i].InstructorName);
		file >> courses[i].CreditHours
		     >> courses[i].MaxCapacity
		     >> courses[i].CurrentEnrolled;
		file.ignore();
		getline(file, courses[i].Day);
		getline(file, courses[i].Time);
	}
	file.close();
}

void saveCourses() {
	ofstream file("courses.txt");
	file << courseCount << "\n";
	for (int i = 0; i < courseCount; i++) {
		file << courses[i].CourseID        << "\n"
		     << courses[i].CourseName      << "\n"
		     << courses[i].InstructorName  << "\n"
		     << courses[i].CreditHours     << "\n"
		     << courses[i].MaxCapacity     << "\n"
		     << courses[i].CurrentEnrolled << "\n"
		     << courses[i].Day             << "\n"
		     << courses[i].Time            << "\n";
	}
	file.close();
}

int searchCourse(int courseID) {
	for (int i = 0; i < courseCount; i++) {
		if (courses[i].CourseID == courseID)
			return i;
	}
	return -1;
}

bool addCourse() {
	if (courseCount >= 20) {
		cout << "Sorry! Max limit reached, cannot add more courses.\n";
		return false;
	}
	Course newCourse;
	cout << "--- Add New Course ---\n";
	cout << "Enter Course ID: ";
	cin >> newCourse.CourseID;

	for (int i = 0; i < courseCount; i++) {
		if (courses[i].CourseID == newCourse.CourseID) {
			cout << "Course ID already exists!\n";
			return false;
		}
	}

	cin.ignore();
	cout << "Enter Course Name: ";      getline(cin, newCourse.CourseName);
	cout << "Enter Instructor Name: ";  getline(cin, newCourse.InstructorName);
	cout << "Enter Credit Hours: ";     cin >> newCourse.CreditHours;
	cout << "Enter Max Capacity: ";     cin >> newCourse.MaxCapacity;
	newCourse.CurrentEnrolled = 0;
	cin.ignore();
	cout << "Enter Day: ";   getline(cin, newCourse.Day);
	cout << "Enter Time: ";  getline(cin, newCourse.Time);

	courses[courseCount++] = newCourse;
	saveCourses();
	cout << "Course added successfully.\n";
	return true;
}

void editCourse() {
	int id;
	cout << "Enter Course ID to edit: ";
	cin >> id;
	int index = searchCourse(id);
	if (index == -1) { cout << "Course not found.\n"; return; }

	cout << "Editing: " << courses[index].CourseName << "\n";
	cout << "1. Course Name\n2. Instructor Name\n3. Credit Hours\n"
	     << "4. Max Capacity\n5. Day\n6. Time\nChoice: ";
	int choice; cin >> choice;
	cin.ignore();

	switch (choice) {
		case 1: cout << "New name: ";         getline(cin, courses[index].CourseName);     break;
		case 2: cout << "New instructor: ";   getline(cin, courses[index].InstructorName); break;
		case 3: cout << "New credit hours: "; cin >> courses[index].CreditHours;           break;
		case 4: cout << "New max capacity: "; cin >> courses[index].MaxCapacity;           break;
		case 5: cout << "New day: ";          getline(cin, courses[index].Day);            break;
		case 6: cout << "New time: ";         getline(cin, courses[index].Time);           break;
		default: cout << "Invalid choice.\n"; return;
	}
	saveCourses();
	cout << "Course updated successfully.\n";
}

void deleteCourse() {
	int id;
	cout << "Enter Course ID to delete: ";
	cin >> id;
	int index = searchCourse(id);
	if (index == -1) { cout << "Course not found.\n"; return; }
	if (courses[index].CurrentEnrolled > 0) {
		cout << "Cannot delete: students are enrolled.\n";
		return;
	}
	for (int i = index; i < courseCount - 1; i++)
		courses[i] = courses[i + 1];
	courseCount--;
	saveCourses();
	cout << "Course deleted successfully.\n";
}


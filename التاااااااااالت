void loadCourses() {
	ifstream file("courses.txt");
	if (!file) return;
	file >> courseCount;
	file.ignore();
	for (int i = 0; i < courseCount; i++) {
		file >> courses[i].CourseID;
		file.ignore();
		getline(file, courses[i].CourseName);
		getline(file, courses[i].InstructorName);
		file >> courses[i].CreditHours
		     >> courses[i].MaxCapacity
		     >> courses[i].CurrentEnrolled;
		file.ignore();
		getline(file, courses[i].Day);
		getline(file, courses[i].Time);
	}
	file.close();
}

void saveCourses() {
	ofstream file("courses.txt");
	file << courseCount << "\n";
	for (int i = 0; i < courseCount; i++) {
		file << courses[i].CourseID        << "\n"
		     << courses[i].CourseName      << "\n"
		     << courses[i].InstructorName  << "\n"
		     << courses[i].CreditHours     << "\n"
		     << courses[i].MaxCapacity     << "\n"
		     << courses[i].CurrentEnrolled << "\n"
		     << courses[i].Day             << "\n"
		     << courses[i].Time            << "\n";
	}
	file.close();
}

int searchCourse(int courseID) {
	for (int i = 0; i < courseCount; i++) {
		if (courses[i].CourseID == courseID)
			return i;
	}
	return -1;
}

bool addCourse() {
	if (courseCount >= 20) {
		cout << "Sorry! Max limit reached, cannot add more courses.\n";
		return false;
	}
	Course newCourse;
	cout << "--- Add New Course ---\n";
	cout << "Enter Course ID: ";
	cin >> newCourse.CourseID;

	for (int i = 0; i < courseCount; i++) {
		if (courses[i].CourseID == newCourse.CourseID) {
			cout << "Course ID already exists!\n";
			return false;
		}
	}

	cin.ignore();
	cout << "Enter Course Name: ";      getline(cin, newCourse.CourseName);
	cout << "Enter Instructor Name: ";  getline(cin, newCourse.InstructorName);
	cout << "Enter Credit Hours: ";     cin >> newCourse.CreditHours;
	if (cin.fail()) { cin.clear(); cin.ignore(1000, '\n'); cout << "Invalid input! Numbers only.\n"; return false; }
	cout << "Enter Max Capacity: ";     cin >> newCourse.MaxCapacity;
	if (cin.fail()) { cin.clear(); cin.ignore(1000, '\n'); cout << "Invalid input! Numbers only.\n"; return false; }
	newCourse.CurrentEnrolled = 0;
	cin.ignore();
	cout << "Enter Day: ";   getline(cin, newCourse.Day);
	cout << "Enter Time: ";  getline(cin, newCourse.Time);

	courses[courseCount++] = newCourse;
	saveCourses();
	cout << "Course added successfully.\n";
	return true;
}


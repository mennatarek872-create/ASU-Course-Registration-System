void deleteCourse() {
	int id;
	cout << "Enter Course ID to delete: ";
	cin >> id;
	if (cin.fail()) {
		cin.clear();
		cin.ignore(1000, '\n');
		cout << "Invalid input! Numbers only.\n";
		return;
	}
	cin.ignore();

	int index = searchCourse(id);
	if (index == -1) { cout << "Course not found.\n"; return; }
	if (courses[index].CurrentEnrolled > 0) {
		cout << "Cannot delete: students are enrolled.\n";
		return;
	}
	for (int i = index; i < courseCount - 1; i++)
		courses[i] = courses[i + 1];
	courseCount--;
	saveCourses();
	cout << "Course deleted successfully.\n";
}
